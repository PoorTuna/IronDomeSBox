
# This file describes files and paths that should not be tracked by Git version control
# https://git-scm.com/docs/gitignore

# Auto-generated code editor files
.vs/*
.vscode/*
*.csproj
obj
bin
Properties/*
code/obj/*
code/Properties/*

# Auto-generated asset related files
.sbox/*
*.generated.*
*.*_c
!*.shader_c
*.los
*.vpk
*launchSettings.json
*.sln
*.slnx

*idea

# Exported / standalone games
Exports/

# Local agent notes
.claude/

# Editor scratch
*.scene_d

# Track imported 84mm missile compiled assets (vendored from facepunch.84mmmissile)
!Assets/models/weapons/sbox_ammo/**
